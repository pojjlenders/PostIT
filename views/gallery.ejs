<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <title>Gallery</title>
    <style>
        .gallery-container { display: flex; flex-wrap: wrap; gap: 20px; }
        .post-card { border: 1px solid #ddd; padding: 10px; width: 250px; text-align: center; }
        .post-card img { max-width: 100%; height: 150px; object-fit: cover; }
    </style>
</head>
<body>
    <h1>La mia Gallery</h1>
    <div class="gallery-container">
        <% posts.forEach(post => { %>
            <div class="post-card">
                <a href="/post/<%= post.id %>">
                    <img src="<%= post.imageUrl %>" alt="<%= post.title %>">
                    <h3><%= post.title %></h3>
                </a>
            </div>
        <% }) %>
    </div>
    <br>
    <a href="/post">Aggiungi nuovo post</a>
</body>
</html>